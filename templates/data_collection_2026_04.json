3},{"id":"234c7543-de3d-417e-9d49-10d44e5c3c5d","value":"234c7543-de3d-417e-9d49-10d44e5c3c5d","label":"Admin Notes","order":4}],"userScope":"all","sessionScope":"current","metadataColumns":{"showAuthorName":false,"showCreatedAt":false}}}],"blocks":[{"id":"b6963f37-8c0c-49d1-a8e2-bf00117cb0fb","page_id":"0964395a-0121-4594-95bd-4fe5b116cc8b","workflow_id":"91dc527b-e400-405b-8433-0d0152c0b9e2","type":"string","label":"Short text information","placeholder":"","content":null,"help_text":"{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"Use the Text Field block for shorter pieces of information, such as names, locations, and other data points that can be entered in just a few words.\"}]}]}","required":true,"multiple":null,"options":{"hideLabel":null},"created_at":"2026-01-28T17:22:12.739Z","updated_at":"2026-01-28T17:22:12.739Z","order":2,"rule":null,"parent_id":null,"sheet_id":"ef5d8955-cba6-46e3-a040-d00aebeed7d7","column_id":"f27ece5d-06a3-4479-a2a5-2f3ce76398b3","url":null,"archived_at":null,"input_column_id":null,"section_id":"b3eb25d6-36e8-4551-b288-bb59b1ec7ec1","embedded_workflow_id":null,"embedded_block_id":null},{"id":"feab13a2-0191-438f-b3e7-305b4b1a655f","page_id":"0964395a-0121-4594-95bd-4fe5b116cc8b","workflow_id":"91dc527b-e400-405b-8433-0d0152c0b9e2","type":"textarea","label":"Longer information","placeholder":null,"content":null,"help_text":"{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"Use the Text Area block for longer pieces of information that may require the user to write a few sentences. This block is suitable for inputs such as “How did you hear about us?” or “Do you require any special assistance? If so, please tell us more.”\"}]}]}","required":true,"multiple":null,"options":{"hideLabel":null},"created_at":"2026-01-28T17:24:59.973Z","updated_at":"2026-01-28T17:24:59.973Z","order":4,"rule":null,"parent_id":null,"sheet_id":"ef5d8955-cba6-46e3-a040-d00aebeed7d7","column_id":"43dd17b6-08c7-4ea8-80c0-ba7fd45a9e0c","url":null,"archived_at":null,"input_column_id":null,"section_id":"b3eb25d6-36e8-4551-b288-bb59b1ec7ec1","embedded_workflow_id":null,"embedded_block_id":null},{"id":"9b8017ca-a6ab-418b-9099-2d9b0ca0c654","page_id":"0964395a-0121-4594-95bd-4fe5b116cc8b","workflow_id":"91dc527b-e400-405b-8433-0d0152c0b9e2","type":"content","label":null,"placeholder":null,"content":"{\"type\":\"doc\",\"content\":[{\"type\":\"heading\",\"attrs\":{\"textAlign\":\"left\",\"level\":2},\"content\":[{\"type\":\"text\",\"text\":\"Your information\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"}},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"Welcome to this data collection template. Please update all the text in orange found in this template, starting with the introduction below so that it clearly explains why personal information is being collected and how it will be used.\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"}},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"For example:\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"}},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"“Welcome to our onboarding process! Before we get started, please provide the information requested so we can direct you to the appropriate onboarding path. The details you submit will be added to your company profile and will be accessible to employees across the organization.”\"}]}]}","help_text":null,"required":null,"multiple":null,"options":null,"created_at":"2026-01-28T16:54:58.306Z","updated_at":"2026-01-28T16:54:58.306Z","order":1,"rule":null,"parent_id":null,"sheet_id":"ef5d8955-cba6-46e3-a040-d00aebeed7d7","column_id":null,"url":null,"archived_at":null,"input_column_id":null,"section_id":"b3eb25d6-36e8-4551-b288-bb59b1ec7ec1","embedded_workflow_id":null,"embedded_block_id":null},{"id":"498f233a-fe79-4610-be41-f2be43e641a8","page_id":"0964395a-0121-4594-95bd-4fe5b116cc8b","workflow_id":"91dc527b-e400-405b-8433-0d0152c0b9e2","type":"single-select","label":"Selection boxes","placeholder":null,"content":null,"help_text":"{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"If you need to ask a multiple-choice question, use the Single Select block. Example use cases include “Which team do you belong to?” or “How would you rate your previous experience?”\"}]}]}","required":true,"multiple":null,"options":{"hideLabel":null},"created_at":"2026-01-28T17:31:23.057Z","updated_at":"2026-01-28T17:31:23.057Z","order":5,"rule":null,"parent_id":null,"sheet_id":"ef5d8955-cba6-46e3-a040-d00aebeed7d7","column_id":"a3a4f8bf-0d0c-46d5-892b-5565489373e8","url":null,"archived_at":null,"input_column_id":null,"section_id":"b3eb25d6-36e8-4551-b288-bb59b1ec7ec1","embedded_workflow_id":null,"embedded_block_id":null},{"id":"d33a174c-f2c6-4792-8935-8b14191f4e0e","page_id":"38a94b48-58af-492e-8941-96f2767aaca0","workflow_id":"91dc527b-e400-405b-8433-0d0152c0b9e2","type":"content","label":null,"placeholder":null,"content":"{\"type\":\"doc\",\"content\":[{\"type\":\"heading\",\"attrs\":{\"textAlign\":\"left\",\"level\":1},\"content\":[{\"type\":\"text\",\"text\":\"Admin Pannel\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"}},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"This is where your admin staff can review all the received data inputs in one single place. The regular users won't have access to this part of the map, only the ones with the admin role that gives them access.\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"}},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"Admins can also add additional information to, or edit, user inputs by configuring the sheet accordingly. In this example, each user input has been preconfigured with an extra “Admin Notes” field that is hidden from the user. To add a note, simply double-click the original input and enter the new information.\"}]}]}","help_text":null,"required":null,"multiple":null,"options":null,"created_at":"2026-01-28T18:14:40.847Z","updated_at":"2026-01-28T18:14:40.847Z","order":1,"rule":null,"parent_id":null,"sheet_id":"ef5d8955-cba6-46e3-a040-d00aebeed7d7","column_id":null,"url":null,"archived_at":null,"input_column_id":null,"section_id":"a1fa58fe-a98e-4a5e-adfa-4d256a61052e","embedded_workflow_id":null,"embedded_block_id":null},{"id":"54b10097-99fb-4d92-b98e-51e2d1068602","page_id":"0964395a-0121-4594-95bd-4fe5b116cc8b","workflow_id":"91dc527b-e400-405b-8433-0d0152c0b9e2","type":"email","label":"Specialized input","placeholder":"","content":null,"help_text":"{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":\"left\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"textStyle\",\"attrs\":{\"color\":\"#e27300\"}}],\"text\":\"Some of our blocks, such as Email, URL, Phone, Number, or Date, are specialized for specific types of input. If you’re collecting one of these types of information, using these specialized blocks helps keep the data standardized.\"}]}]}","r